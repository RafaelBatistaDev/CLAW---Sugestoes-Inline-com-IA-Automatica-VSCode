# .env.example - Variáveis de Ambiente para CLAW v1.1.9

# ==========================================
# 🤖 Configurações de IA
# ==========================================

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LocalAI / Ollama
LOCALAI_ENDPOINT=http://localhost:8080
OLLAMA_ENDPOINT=http://localhost:11434

# ==========================================
# 🔧 Configurações da Extensão
# ==========================================

# Ativar/Desativar sugestões
CLAW_ENABLED=true

# Nível de logging (off, error, warn, info, debug)
CLAW_LOG_LEVEL=info

# Debounce em ms (intervalo para sugestões)
CLAW_DEBOUNCE_MS=500

# Máximo de tokens por sugestão
CLAW_MAX_TOKENS=150

# Usar LocalAI para tarefas simples (ZERO API)
CLAW_ENABLE_LOCALAI=true

# ==========================================
# 🐍 Configurações Python/Agent
# ==========================================

# Caminho para agent.py
AGENT_PYTHON_PATH=~/.local/bin/agent.py

# Python executable
PYTHON_EXECUTABLE=python3

# ==========================================
# 🎨 Desenvolvimento
# ==========================================

# Modo de desenvolvimento
DEV_MODE=false

# Debug detalhado
DEBUG=false

# ==========================================
# 📦 Build & Release
# ==========================================

# Versão (não alterar durante v1.1.9 testes)
EXTENSION_VERSION=1.1.9

# Publisher no Marketplace
PUBLISHER=RafaelBatista

# ==========================================

# Instruções:
# 1. Copie este arquivo para .env
# 2. Preencha com suas chaves/configurações
# 3. NÃO commite .env no git (já está em .gitignore)
# 4. Use durante desenvolvimento: npm run dev
